# Postgres — used by Prisma (keep both; pooler URL for runtime, direct for migrations)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Supabase Auth
# Find these in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."   # safe to be public
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."        # keep secret — server-side only

# Used by the user-migration script (scripts/migrate-users-to-supabase.ts)
# Set to your production URL so password-reset links redirect to the right place.
APP_URL="https://your-app.vercel.app"
