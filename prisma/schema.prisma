generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AssessmentComponentType {
  INTERNAL
  EXTERNAL
}

model User {
  id          String   @id @default(cuid())
  supabaseId  String?  @unique  // Supabase Auth UUID; null until user is migrated / created via new flow
  email       String   @unique
  title       String   @default("Dr.")
  firstName   String   @default("")
  lastName    String   @default("")
  name        String
  role        String   @default("FACULTY") // Base account access only; mentoring is assigned per course offering.
  isAdmin     Boolean  @default(false)
  faculty     Faculty?
  mentorAssignments CourseOfferingMentor[]
  createdAt   DateTime @default(now())
}

model Faculty {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  sections  Section[]
  offeringAssignments CourseOfferingClass[]
}

model Subject {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  program     String
  isActive    Boolean  @default(true)
  offerings   CourseOffering[]
  createdAt   DateTime @default(now())
}

model Section {
  id                String    @id @default(cuid())
  name              String    // Admin-defined section/group label; not globally unique across batches/courses.
  isElectiveClass   Boolean   @default(false)
  facultyId         String?
  faculty           Faculty?  @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  students          Student[]
  rollPrefix        String?
  schoolCode        String?
  levelCode         String?
  programDurationYears Int?
  programCode       String?
  admissionYear     String?
  expectedGraduationYear String?
  sectionCode       String?
  program           String?
  term              String? // legacy backfill / compatibility only — migrate reads to CourseOffering
  academicYear      String? // legacy backfill / compatibility only — migrate reads to CourseOffering
  semester          String?
  year              String?
  evaluationPattern String? // legacy backfill / compatibility only — migrate reads to CourseOffering
  courseType        String? // legacy backfill / compatibility only — migrate reads to CourseOffering
  isActive          Boolean  @default(true)
  offeringAssignments CourseOfferingClass[]
  offeringEnrollments CourseOfferingEnrollment[]

  @@index([facultyId])
  @@index([name])
  @@index([programCode, admissionYear, sectionCode])
}

model Student {
  id                   String    @id @default(cuid())
  rollNo               String    @unique
  name                 String
  sectionId            String
  excludeFromAnalytics Boolean   @default(false)
  section              Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  marks                Mark[]
  offeringEnrollments CourseOfferingEnrollment[]

  // TODO: Add a canonical cross-offering student identity layer so mixed elective
  // enrollments and regular class enrollments can be analyzed together later.

  @@index([sectionId])
  @@index([sectionId, excludeFromAnalytics])
}

model ArchivedStudent {
  id                   String   @id @default(cuid())
  originalStudentId    String
  rollNo               String
  name                 String
  sectionId            String?
  sectionName          String
  excludeFromAnalytics Boolean  @default(false)
  archivedAt           DateTime @default(now())
  archivedByUserId     String?
  archiveReason        String
  snapshot             Json
  restoredAt           DateTime?
  restoredByUserId     String?
  restoredStudentId    String?
}

model StudentDeletionRequest {
  id               String   @id @default(cuid())
  studentId        String?
  studentRollNo    String
  studentName      String
  sectionName      String
  requestedByUserId String
  requestedByName  String
  reason           String?
  status           String   @default("PENDING")
  reviewedAt       DateTime?
  reviewedByUserId String?
  reviewNote       String?
  createdAt        DateTime @default(now())

  @@index([status, createdAt])
  @@index([studentId, status])
}

model Assessment {
  id            String         @id @default(cuid())
  offeringId    String
  offering      CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  name          String
  code          String
  description   String?
  maxMarks      Float
  weightage     Float          @default(0)
  category      String         // e.g., "CA_QUIZ", "CA_REVIEW", "MID_TERM", "END_SEMESTER"
  componentType AssessmentComponentType @default(INTERNAL)
  isActive      Boolean        @default(true)
  includeInAgg  Boolean        @default(true)
  displayOrder  Int            @default(0)
  marks         Mark[]

  @@unique([offeringId, code])
  @@index([offeringId, isActive, displayOrder])
  @@index([offeringId, category])
}

model Mark {
  id           String     @id @default(cuid())
  studentId    String
  assessmentId String
  marks        Float
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([studentId, assessmentId])
  @@index([assessmentId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String
  details   Json
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
}

model CourseOffering {
  id                String    @id @default(cuid())
  subjectId         String
  subject           Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  term              String
  academicYear      String
  semester          String
  year              String
  evaluationPattern String
  courseType        String
  isElective        Boolean   @default(false)
  isActive          Boolean   @default(true)
  gradeRulesConfig  Json?
  assessments       Assessment[]
  classAssignments  CourseOfferingClass[]
  enrollments       CourseOfferingEnrollment[]
  mentorAssignments CourseOfferingMentor[]
  createdAt         DateTime  @default(now())

  @@index([isActive, academicYear, term])
  @@index([subjectId, isActive])
}

model CourseOfferingClass {
  id         String         @id @default(cuid())
  offeringId String
  sectionId  String
  facultyId  String?
  offering   CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  section    Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  faculty    Faculty?       @relation(fields: [facultyId], references: [id], onDelete: SetNull)

  @@unique([offeringId, sectionId])
  @@index([offeringId, facultyId])
  @@index([facultyId])
  @@index([sectionId])
}

model CourseOfferingMentor {
  id         String         @id @default(cuid())
  offeringId String
  userId     String
  offering   CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([offeringId, userId])
  @@index([userId])
}

model CourseOfferingEnrollment {
  id         String         @id @default(cuid())
  offeringId String
  studentId  String
  sectionId  String
  offering   CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  student    Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section    Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([offeringId, studentId])
  @@index([offeringId, sectionId])
  @@index([studentId])
  @@index([sectionId])
}
